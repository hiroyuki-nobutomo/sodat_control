# Files Vercel doesn't need: keep docs/ (static site), api/ (serverless
# functions), vercel.json, and user_data_snippet.yaml.template (read at
# request time by api/firstrun.js). Everything else is Pi-side runtime code
# or secrets and should not be uploaded.

# Python — Pi runtime, never executed on Vercel
src/
scripts/
*.py
*.pyc
__pycache__/
.venv/
venv/
requirements.txt

# Shell scripts (installer / bootstrap) — Pi-side only
*.sh
*.sh.template

# Hardware / data / secrets
arduino/
data/
secrets/

# Config & misc — block by default, then un-ignore the one the function reads
config.yaml
config.yaml.template
*.yaml
*.yml
!user_data_snippet.yaml.template
*.db
*.log
mock_uploads.jsonl

# Tooling state
.git/
.gitignore
.claude/

# Files Vercel doesn't need: keep docs/ (static site), api/ (serverless
# functions), and vercel.json. Everything else is Pi-side runtime code or
# secrets and should not be uploaded. (The cloud-init template is inlined
# into api/firstrun.js, so no template file needs to be bundled.)

# Python — Pi runtime, never executed on Vercel
src/
scripts/
*.py
*.pyc
__pycache__/
.venv/
venv/
requirements.txt

# Shell scripts (installer / bootstrap) — Pi-side only
*.sh
*.sh.template

# Hardware / data / secrets
arduino/
data/
secrets/

# Config & misc
config.yaml
config.yaml.template
*.yaml
*.yml
*.db
*.log
mock_uploads.jsonl

# Tooling state
.git/
.gitignore
.claude/
